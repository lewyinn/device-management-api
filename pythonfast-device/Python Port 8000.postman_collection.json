              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"values\": {\n    \"temperature\": 28.5,\n    \"humidity\": 75.2\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/devices/{{device_id}}/telemetry",
              "host": [
